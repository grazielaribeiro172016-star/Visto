rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'name', 'contactType', 'contactValue']) &&
             data.uid == request.auth.uid &&
             data.name is string && data.name.size() > 0 && data.name.size() < 50 &&
             data.contactType in ['whatsapp', 'telegram', 'email'] &&
             data.contactValue is string && data.contactValue.size() > 0;
    }
    
    function isValidThought(data) {
      return data.keys().hasAll(['uid', 'authorName', 'text', 'contactType', 'contactValue', 'createdAt']) &&
             data.uid == request.auth.uid &&
             data.text is string && data.text.size() > 0 && data.text.size() <= 180 &&
             data.authorName is string &&
             data.contactType in ['whatsapp', 'telegram', 'email'] &&
             data.createdAt is timestamp;
    }

    // User Profiles
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create, update: if isOwner(userId) && isValidUser(request.resource.data);
    }

    // Thoughts
    match /thoughts/{thoughtId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidThought(request.resource.data);
      allow update, delete: if isAuthenticated() && resource.data.uid == request.auth.uid;
    }
  }
}
